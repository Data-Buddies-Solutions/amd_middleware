# Copy to .env for local use only. Never commit real values.

# AdvancedMD API credentials (required)
ADVANCEDMD_USERNAME=your_username
ADVANCEDMD_PASSWORD=your_password
ADVANCEDMD_OFFICE_KEY=your_office_key
ADVANCEDMD_APP_NAME=your_app_name

# API security (API_SECRET required; use a distinct booking secret in production)
API_SECRET=random_secret_for_middleware_api
BOOKING_TOKEN_SECRET=random_secret_for_signed_slot_tokens

# Runtime configuration
PORT=8080
AMD_ENV=dev

# Temporary legacy escape hatch (default false)
ALLOW_RAW_SLOT_BOOKING=false
